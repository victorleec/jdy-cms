# 金蝶筋斗云 API 配置

# API 基础地址 (通常为 https://api.kingdee.com)
JDY_API_BASE_URL=https://api.kingdee.com

# 认证信息 - Client 维度
# 应用ID (Header: X-Api-ClientID)
JDY_CLIENT_ID=
# 应用密钥 (Header: X-Api-Signature 签名使用)
# 如果文档未明确提供，有时可能与 APP_SECRET 相同
JDY_CLIENT_SECRET=

# 认证信息 - App/Tenant 维度
# 授权Key (Param: app_key)
JDY_APP_KEY=
# 授权密钥 (Param: app_signature 签名使用)
JDY_APP_SECRET=

# 业务 ID (部分接口必须)
# 账套ID (dbId)
JDY_ENTERPRISE_ID=
# 服务ID (sId)
JDY_SERVICE_ID=
